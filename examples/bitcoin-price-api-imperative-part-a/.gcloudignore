# This file specifies files that are *not* uploaded to Google Cloud
# using gcloud. It follows the same syntax as .gitignore

.gcloudignore
.git
.gitignore
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# Local development files
runtime/
*.csv
*.log
.env
.venv

# Documentation
docs/
README.md
*.md

# Tests
tests/
test_*.py
*_test.py

# IDE
.vscode/
.idea/
*.swp
*.swo
