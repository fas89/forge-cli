# Environment Configuration Template
# Copy this file to .env.dev, .env.staging, or .env.prod

# Environment name
FLUID_ENV=development

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fluid_dev
DB_USER=fluid_user
DB_PASSWORD=changeme

# Output configuration
OUTPUT_SCHEMA=analytics_dev
OUTPUT_TABLE_PREFIX=dev_

# Feature flags
ENABLE_DATA_QUALITY_CHECKS=true
ENABLE_INCREMENTAL_LOAD=false
ENABLE_NOTIFICATIONS=false

# Performance tuning
MAX_WORKERS=4
BATCH_SIZE=1000

# API keys (use secrets manager in production)
API_KEY=dev_api_key_12345
ANALYTICS_TOKEN=dev_token_67890
