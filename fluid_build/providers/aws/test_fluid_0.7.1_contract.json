{
  "id": "financial-analytics-eu-compliant",
  "name": "Financial Analytics - GDPR Compliant",
  "version": "1.0.0",
  "metadata": {
    "domain": "finance",
    "owner": "data-platform-team@acme.com",
    "classification": "confidential",
    "contains_pii": true,
    "compliance": ["GDPR", "SOC2", "PCI-DSS"],
    "retention_days": 2555,
    "environment": "production"
  },
  "sovereignty": {
    "jurisdiction": "EU",
    "dataResidency": ["eu-west-1", "eu-central-1"],
    "tags": ["gdpr-compliant", "schrems-ii"],
    "complianceFramework": ["GDPR", "CCPA"]
  },
  "agentPolicy": {
    "allowedModels": ["gpt-4", "claude-3-opus", "gemini-pro"],
    "deniedModels": ["public-llm", "uncertified-model"],
    "usageConstraints": {
      "prohibitedPurposes": ["advertising", "profiling", "surveillance"],
      "allowedPurposes": ["analytics", "research", "reporting", "compliance"]
    },
    "requiresHumanApproval": true,
    "auditLevel": "full",
    "accessTier": "sensitive",
    "rateLimits": {
      "requestsPerHour": 100,
      "requestsPerDay": 1000
    },
    "tags": ["ai-audited", "llm-restricted"]
  },
  "schema": {
    "type": "object",
    "properties": {
      "transaction_id": {
        "type": "string",
        "description": "Unique transaction identifier"
      },
      "customer_id": {
        "type": "string",
        "description": "Customer identifier",
        "pii": true
      },
      "amount": {
        "type": "number",
        "description": "Transaction amount in EUR"
      },
      "timestamp": {
        "type": "string",
        "format": "date-time"
      },
      "merchant_category": {
        "type": "string"
      }
    }
  },
  "exposures": [
    {
      "id": "financial-data-lake",
      "type": "s3",
      "target": "aws-athena",
      "binding": {
        "provider": "aws",
        "location": {
          "region": "eu-west-1",
          "bucket": "acme-financial-analytics-eu",
          "prefix": "transactions/"
        },
        "format": {
          "type": "parquet",
          "compression": "snappy",
          "partitionBy": ["year", "month", "day"]
        },
        "cataloging": {
          "enabled": true,
          "database": "financial_analytics",
          "table": "transactions",
          "updateSchedule": "daily"
        }
      }
    }
  ],
  "orchestration": {
    "engine": "airflow",
    "schedule": "0 2 * * *",
    "timezone": "Europe/Dublin",
    "tasks": [
      {
        "taskId": "ensure_s3_bucket",
        "type": "provider_action",
        "action": "aws.s3.ensure_bucket",
        "params": {
          "bucket": "acme-financial-analytics-eu",
          "region": "eu-west-1",
          "versioning": true,
          "encryption": {
            "type": "AES256"
          },
          "lifecycle": {
            "rules": [
              {
                "id": "archive-old-data",
                "transitions": [
                  {
                    "days": 90,
                    "storageClass": "GLACIER"
                  }
                ],
                "expiration": {
                  "days": 2555
                }
              }
            ]
          }
        }
      },
      {
        "taskId": "ensure_glue_database",
        "type": "provider_action",
        "action": "aws.glue.ensure_database",
        "dependsOn": ["ensure_s3_bucket"],
        "params": {
          "database": "financial_analytics",
          "description": "GDPR-compliant financial analytics database"
        }
      },
      {
        "taskId": "ensure_glue_table",
        "type": "provider_action",
        "action": "aws.glue.ensure_table",
        "dependsOn": ["ensure_glue_database"],
        "params": {
          "database": "financial_analytics",
          "table": "transactions",
          "location": "s3://acme-financial-analytics-eu/transactions/",
          "format": "parquet",
          "partitionKeys": [
            {"name": "year", "type": "int"},
            {"name": "month", "type": "int"},
            {"name": "day", "type": "int"}
          ]
        }
      },
      {
        "taskId": "run_athena_query",
        "type": "provider_action",
        "action": "aws.athena.execute_query",
        "dependsOn": ["ensure_glue_table"],
        "params": {
          "database": "financial_analytics",
          "query": "MSCK REPAIR TABLE transactions",
          "workgroup": "primary"
        }
      }
    ]
  },
  "quality": {
    "expectations": [
      {
        "field": "transaction_id",
        "expectation": "not_null"
      },
      {
        "field": "amount",
        "expectation": "greater_than",
        "value": 0
      }
    ]
  },
  "lineage": {
    "upstream": [
      {
        "dataset": "raw_transactions",
        "type": "kafka_topic"
      }
    ]
  }
}
