@pytest.fixture
def event_stream_contract(fixtures_dir):
    """Load event stream FLUID contract."""
    with open(fixtures_dir / "event_stream.yaml") as f:
        return yaml.safe_load(f)


@pytest.fixture
def minimal_contract(fixtures_dir):
    """Load minimal FLUID contract."""
