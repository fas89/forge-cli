import yaml
from pathlib import Path
from typing import Dict, Any

from fluid_build.providers.odcs import OdcsProvider
from fluid_build.providers.base import ProviderError


@pytest.fixture
def odcs_provider():
    """Create ODCS provider instance."""
    return OdcsProvider()


@pytest.fixture
def fixtures_dir():
    """Get fixtures directory path."""
    return Path(__file__).parent.parent / "fixtures" / "contracts"


@pytest.fixture
def customer_analytics_contract(fixtures_dir):
    """Load customer analytics FLUID contract."""
    with open(fixtures_dir / "customer_analytics.yaml") as f:
        return yaml.safe_load(f)


@pytest.fixture
def sales_reporting_contract(fixtures_dir):
    """Load sales reporting FLUID contract."""
    with open(fixtures_dir / "sales_reporting.yaml") as f:
